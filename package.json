{
  "name": "fragments",
  "private": true,
  "version": "0.7.0",
  "description": "Fragments back-end API",
  "scripts": {
    "test:watch": "jest -c jest.config.js --runInBand --watch --",
    "test": "jest -c jest.config.js --runInBand --",
    "coverage": "jest -c jest.config.js --runInBand --coverage",
    "lint": "eslint \"./src/**/*.js\" \"tests/**/*.js\"",
    "start": "node src/index.js",
    "dev": "cross-env FRAGMENTS_LOG_LEVEL=debug nodemon --watch src src/index.js",
    "debug": "cross-env DEBUG=true npm run dev"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/goodgirl20/fragments.git"
  },
  "author": "Grace Elezabeth Thomas",
  "license": "UNLICENSED",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "prettier": "3.8.3",
    "supertest": "^7.2.2"
  },
  "dependencies": {
    "aws-jwt-verify": "^5.1.1",
    "content-type": "^2.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "markdown-it": "^14.3.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "stoppable": "^1.1.0"
  }
}
